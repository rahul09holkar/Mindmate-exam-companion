# MindMate Exam Companion — environment configuration
#
# All AI configuration is SERVER-SIDE ONLY. Do not prefix any of these with
# NEXT_PUBLIC_ — that would expose the secret to the browser.
#
# If no key is set, MindMate runs in deterministic MOCK MODE: the offline
# analyzer produces structured reflections so the app works without any key.
#
# Copy this file to `.env.local` and add your key there (.env.local is
# git-ignored, so your secret is never committed).

# Optional. When set, journal analysis uses the OpenAI Chat Completions API.
# Leave empty to use mock mode.
OPENAI_API_KEY=

# Optional. Overrides the default model used for analysis.
# Examples: gpt-4o-mini, gpt-4o
OPENAI_MODEL=gpt-4o-mini
